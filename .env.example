# =============================================================================
# LOVELI LUXURY INTERNATIONAL — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER COMMIT .env.local OR ANY FILE WITH REAL CREDENTIALS.
# CI checks this. Pre-commit hook checks this. Don't try.
#
# Mirrors the Zod schema in src/lib/env.ts. Required vars throw at startup if
# missing/malformed; optional vars degrade gracefully (the feature they power
# is a no-op until set). "Optional" is noted per var.
# =============================================================================

# -----------------------------------------------------------------------------
# Application (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Loveli Luxury International

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
# Public, safe to expose to the browser (paired with strict RLS).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only. Bypasses RLS. Treat like a root password. Min 20 chars.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_NEVER_TO_BROWSER

# -----------------------------------------------------------------------------
# IntaSend — collections (STK + card + bank) + payouts (B2C + bank transfer)
# -----------------------------------------------------------------------------
# Server-only. IntaSend is the ONLY payment provider (PayHero retired
# 2026-06-03 — see docs/intasend-migration-2026-06.md).
#
# INTASEND_PUBLISHABLE_KEY: pk_test_... or pk_live_... from the IntaSend
#   dashboard. Despite the "publishable" naming, we keep it server-only
#   except when explicitly handing it to the IntaSend inline-checkout
#   widget on a single checkout page.
INTASEND_PUBLISHABLE_KEY=
# ISSecretKey_... — the API secret. NEVER expose to the browser bundle.
INTASEND_SECRET_TOKEN=
# The IntaSend wallet collections land in and payouts draw from. Acts as
# the platform's float account. Get this id from the IntaSend dashboard's
# Wallets page.
INTASEND_WALLET_ID=
# Shared secret IntaSend signs webhook bodies with. Signature verification
# is MANDATORY on every webhook (src/lib/intasend/signature.ts). Min 20 chars.
# Generate with: openssl rand -hex 32 — and paste the same value into the
# IntaSend dashboard's webhook configuration.
INTASEND_WEBHOOK_CHALLENGE=
# 'true' → sandbox (the SDK targets sandbox.intasend.com). Anything else
# (including unset) → live. Set to 'true' until the owner explicitly
# approves go-live.
INTASEND_TEST=true
# KES whole-shilling ceiling above which a payout requires a superadmin
# approval action before it fires. Defaults to 100,000 if unset.
INTASEND_PAYOUT_APPROVAL_CEILING_KES=100000

# -----------------------------------------------------------------------------
# On-demand revalidation (POST /api/revalidate) — required
# -----------------------------------------------------------------------------
# Bearer token for trusted server-side clients (admin tooling, scheduled jobs,
# deploy hooks) to flush ISR caches for catalog routes. Min 32 chars.
# Generate with:  openssl rand -hex 32
REVALIDATE_SECRET=generate_a_random_64_char_hex_string_here_______________________

# Bearer secret for the Vercel-cron endpoints (/api/cron/*). Optional; min 32
# chars when set. Generate with:  openssl rand -hex 32
CRON_SECRET=

# -----------------------------------------------------------------------------
# Upstash Redis — rate limiting (optional; limiter is a no-op / fail-open if unset)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Resend — transactional email / order receipts (optional; no-op if unset)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@loveliluxuryscents.com

# -----------------------------------------------------------------------------
# Africa's Talking — SMS for MSISDN verification (optional)
# -----------------------------------------------------------------------------
# If unset, verification codes are written to audit_log for manual relay, so the
# flow runs end-to-end without an SMS provider configured.
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SENDER_ID=

# -----------------------------------------------------------------------------
# Sentry — error tracking (optional; no-op if DSN unset)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=loveli-luxury
SENTRY_PROJECT=storefront

# -----------------------------------------------------------------------------
# WhatsApp concierge (optional). E.164 format, e.g. +254712345678.
# When unset, the floating concierge button renders nothing (safe degrade).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_CONCIERGE_NUMBER=

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# -----------------------------------------------------------------------------
# Feature flags (optional; default false)
# -----------------------------------------------------------------------------
ENABLE_DISTRIBUTOR_SIGNUP=false
ENABLE_PAYOUTS=false
ENABLE_MAINTENANCE_MODE=false

# Admin 2FA enforcement. 'true' => admins with an enrolled TOTP factor must pass
# an aal2 challenge to use /admin. Default off (inert). See delivery punch-list.
ENFORCE_ADMIN_MFA=false
