# =============================================================================
# LOVELI LUXURY INTERNATIONAL — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER COMMIT .env.local OR ANY FILE WITH REAL CREDENTIALS.
# CI checks this. Pre-commit hook checks this. Don't try.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Loveli Luxury International

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Public, safe to expose to browser (paired with strict RLS)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_NEW_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_NEW_ANON_KEY_AFTER_ROTATION

# Server-only. Bypasses RLS. Treat like a root password.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_NEVER_TO_BROWSER

# -----------------------------------------------------------------------------
# Flutterwave (unified payments + payouts)
# -----------------------------------------------------------------------------
# Server-only
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxx-X
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TESTxxxxxxxxxx

# Public, used to initialize the inline checkout
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxx-X

# Webhook signing secret (set in Flutterwave dashboard, must match)
FLUTTERWAVE_WEBHOOK_SECRET_HASH=set_a_long_random_string

# -----------------------------------------------------------------------------
# On-demand revalidation (POST /api/revalidate)
# -----------------------------------------------------------------------------
# Bearer token used by trusted server-side clients (admin tooling, scheduled
# jobs, deploy hooks) to flush ISR caches for catalog routes. Min 32 chars.
# Generate with:  openssl rand -hex 32
REVALIDATE_SECRET=generate_a_random_64_char_hex_string_here_______________________

# -----------------------------------------------------------------------------
# Sentry (error tracking)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=loveli-luxury
SENTRY_PROJECT=storefront

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=orders@loveliluxuryscents.com

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# -----------------------------------------------------------------------------
# Feature flags (for staged rollout)
# -----------------------------------------------------------------------------
ENABLE_DISTRIBUTOR_SIGNUP=false
ENABLE_PAYOUTS=false
ENABLE_MAINTENANCE_MODE=false
